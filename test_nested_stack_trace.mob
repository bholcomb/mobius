// Test nested function calls for stack trace
func level3() {
    print("In level3, about to cause error");
    return 1 / 0;  // This should trigger the error with a full stack trace
}

func level2() {
    print("In level2, calling level3");
    return level3();
}

func level1() {
    print("In level1, calling level2");
    return level2();
}

func main_func() {
    print("Starting nested function test");
    return level1();
}

// Call main to start the chain
main_func();
