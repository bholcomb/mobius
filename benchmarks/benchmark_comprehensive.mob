// Comprehensive Mobius Performance Benchmark
//
// This file is kept semantically identical to benchmark_comprehensive.lua and
// benchmark_comprehensive.py. Every benchmark returns an integer checksum, and
// run_benchmarks.py refuses to report timings unless all three languages agree
// on every checksum. If you change a workload here, change it in all three.
//
// Ground rules that keep the comparison honest:
//   * Only operators with identical semantics across the three languages.
//     Mobius `/` truncates and `%` is a C-style remainder; Lua `//` and `%`
//     floor. They agree only on non-negative operands, so every intermediate
//     value below is kept non-negative, and integer division is avoided.
//   * Each language uses its own canonical counted loop (Mobius/Lua `for`,
//     Python `range`), never a hand-rolled `while` in one and `for` in another.
//   * Setup (key building, array preallocation) happens outside the timed
//     region, so each benchmark measures the operation it names.
//
// Output format, one line per benchmark, consumed by run_benchmarks.py:
//   BENCH <id> <seconds> <checksum>

print("=== Mobius Comprehensive Performance Benchmark ===");
print("Benchmark model: arrays = dense integer storage, tables = string-key hash maps");

func ns_to_sec(ns) {
    return float(ns) / 1000000000.0;
}

func report(id, start_ns, checksum) {
    print("BENCH", id, ns_to_sec(clock() - start_ns), checksum);
}

// ============================================================================
// 1. Arithmetic (integer). Operands stay non-negative so % matches Lua/Python.
// ============================================================================
func benchmark_arithmetic() {
    var start = clock();
    var r = 0;
    for (var i = 0; i < 10000000; i++) {
        r = (r + i * 2 + 1) % 1000003;
        r = (r * 3 + 7) % 1000003;
    }
    report("arith", start, r);
    return r;
}

// ============================================================================
// 2. Function calls — recursive fibonacci.
// Deliberately left un-annotated: this is the un-specialized call path.
// ============================================================================
func fibonacci(n) {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

func benchmark_function_calls() {
    var start = clock();
    var result = fibonacci(30);
    report("fib", start, result);
    return result;
}

// ============================================================================
// 3. Array operations (dense numeric storage). Array is preallocated.
// ============================================================================
func benchmark_arrays() {
    var n = 1000000;
    var arr = array_create(n, 0);       // setup: outside the timer
    var start = clock();

    for (var i = 0; i < n; i++) {
        arr[i] = i * 2;
    }
    var sum = 0;
    for (var i = 0; i < n; i++) {
        sum = sum + arr[i];
    }

    report("array", start, sum);
    return sum;
}

// ============================================================================
// 4. Table operations (string-key hash map). Keys are built outside the timer.
// ============================================================================
func build_table_keys(count) {
    var keys = array_create(count);
    for (var i = 0; i < count; i++) {
        keys:push(concat("key_", str(i)));
    }
    return keys;
}

func benchmark_tables() {
    var n = 50000;
    var keys = build_table_keys(n);     // setup: outside the timer
    var start = clock();

    var tbl = {};
    for (var i = 0; i < n; i++) {
        tbl[keys[i]] = i * 3;
    }

    var sum = 0;
    for (var pass = 0; pass < 10; pass++) {
        for (var i = 0; i < n; i++) {
            sum = sum + tbl[keys[i]];
        }
    }

    report("table", start, sum);
    return sum;
}

// ============================================================================
// 5. String operations — build, measure, upcase.
// ============================================================================
func benchmark_strings() {
    var base = "Hello";
    var start = clock();

    var total = 0;
    for (var i = 0; i < 200000; i++) {
        var result = concat(base, " World ", str(i));
        total = total + size(result);
        var upper_result = upper(result);
        total = total + size(upper_result);
    }

    report("string", start, total);
    return total;
}

// ============================================================================
// 6. Nested loops.
// ============================================================================
func benchmark_nested_loops() {
    var start = clock();

    var sum = 0;
    for (var i = 0; i < 3000; i++) {
        for (var j = 0; j < 3000; j++) {
            sum = sum + i * j;
        }
    }

    report("nested", start, sum);
    return sum;
}

// ============================================================================
// 7. Object creation / destruction — allocation churn, inside the timer.
// ============================================================================
func benchmark_object_lifecycle() {
    var start = clock();

    var total = 0;
    for (var i = 0; i < 300000; i++) {
        var temp_array = [1, 2, 3, 4, 5];
        var temp_table = {a: 1, b: 2, c: 3};
        var temp_str = concat("temp", str(i));
        total = total + temp_array[0] + temp_table.a + size(temp_str);
    }

    report("objlife", start, total);
    return total;
}

// ============================================================================
// 8. Mixed workload — build records, then aggregate a field.
// ============================================================================
func benchmark_mixed() {
    var n = 100000;
    var start = clock();

    var data = array_create(n);
    for (var i = 0; i < n; i++) {
        var record = {
            id: i,
            value: i * 2,
            name: concat("item_", str(i))
        };
        data:push(record);
    }

    var total = 0;
    for (var i = 0; i < n; i++) {
        var record = data:get(i);
        total = total + record.value + size(record.name);
    }

    report("mixed", start, total);
    return total;
}

// ============================================================================
// Run all benchmarks
// ============================================================================
var overall_start = clock();

benchmark_arithmetic();
benchmark_function_calls();
benchmark_arrays();
benchmark_tables();
benchmark_strings();
benchmark_nested_loops();
benchmark_object_lifecycle();
benchmark_mixed();

print("BENCH", "total", ns_to_sec(clock() - overall_start), 0);
