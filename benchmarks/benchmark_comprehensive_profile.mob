// Profiling-oriented Mobius benchmark.
// Mirrors tests/benchmark_comprehensive.mob, but loops inside the script so
// perf samples execution rather than process startup, parsing, and compilation.

print("=== Mobius Comprehensive Profiling Benchmark ===\n");

var PROFILE_ITERATIONS = 100;

// ============================================================================
// 1. Arithmetic Operations
// ============================================================================
func benchmark_arithmetic() {
    var result = 0;
    for (var i = 0; i < 1000000; i = i + 1) {
        result = result + i * 2 - 1;
        result = result / 2;
        result = result % 1000;
    }
    return result;
}

// ============================================================================
// 2. Function Calls
// ============================================================================
func fibonacci(n) {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

func benchmark_function_calls() {
    var result = 0;
    for (var i = 0; i < 10; i = i + 1) {
        result = fibonacci(20);
    }
    return result;
}

// ============================================================================
// 3. Array Operations (dense numeric storage)
// ============================================================================
func benchmark_arrays() {
    var arr = array_create(10000);
    for (var i = 0; i < 10000; i = i + 1) {
        arr:push(i * 2);
    }

    var sum = 0;
    for (var i = 0; i < 10000; i = i + 1) {
        sum = sum + arr:get(i);
    }

    return sum;
}

// ============================================================================
// 4. Table Operations (hash map string keys)
// ============================================================================
func build_table_keys(count) {
    var keys = array_create(count);
    for (var i = 0; i < count; i = i + 1) {
        keys:push(concat("key_", str(i)));
    }
    return keys;
}

func benchmark_tables() {
    var keys = build_table_keys(5000);
    var tbl = {};
    for (var i = 0; i < 5000; i = i + 1) {
        var key = keys:get(i);
        tbl[key] = i * 3;
    }

    var sum = 0;
    for (var i = 0; i < 5000; i = i + 1) {
        var key = keys:get(i);
        sum = sum + tbl[key];
    }

    return sum;
}

// ============================================================================
// 5. String Operations
// ============================================================================
func benchmark_strings() {
    var base = "Hello";
    var result = "";
    for (var i = 0; i < 1000; i = i + 1) {
        result = concat(base, " World ", str(i));
        var len_result = len(result);
        var upper_result = upper(result);
    }
    return len(result);
}

// ============================================================================
// 6. Nested Loops
// ============================================================================
func benchmark_nested_loops() {
    var sum = 0;
    for (var i = 0; i < 500; i = i + 1) {
        for (var j = 0; j < 500; j = j + 1) {
            sum = sum + i * j;
        }
    }
    return sum;
}

// ============================================================================
// 7. Object Creation/Destruction
// ============================================================================
func benchmark_object_lifecycle() {
    var last = 0;
    for (var i = 0; i < 10000; i = i + 1) {
        var temp_array = [1, 2, 3, 4, 5];
        var temp_table = {a: 1, b: 2, c: 3};
        var temp_str = concat("temp", str(i));
        last = i;
    }
    return last;
}

// ============================================================================
// 8. Mixed Workload
// ============================================================================
func benchmark_mixed() {
    var data = array_create(1000);
    for (var i = 0; i < 1000; i = i + 1) {
        var record = {
            id: i,
            value: i * 2,
            name: concat("item_", str(i))
        };
        data:push(record);
    }

    var total = 0;
    for (var i = 0; i < 1000; i = i + 1) {
        var record = data:get(i);
        total = total + record.value;
    }

    return total;
}

func run_suite() {
    var checksum = 0;
    checksum = checksum + benchmark_arithmetic();
    checksum = checksum + benchmark_function_calls();
    checksum = checksum + benchmark_arrays();
    checksum = checksum + benchmark_tables();
    checksum = checksum + benchmark_strings();
    checksum = checksum + benchmark_nested_loops();
    checksum = checksum + benchmark_object_lifecycle();
    checksum = checksum + benchmark_mixed();
    return checksum;
}

print("Iterations: ", PROFILE_ITERATIONS);
print("Starting profiling workload...\n");

var overall_start = clock();
var checksum = 0;

for (var iteration = 0; iteration < PROFILE_ITERATIONS; iteration = iteration + 1) {
    checksum = checksum + run_suite();
}

var overall_duration = clock() - overall_start;

print("=== Profiling Results ===");
print("Total time: ", overall_duration, "s");
print("Average iteration time: ", overall_duration / PROFILE_ITERATIONS, "s");
print("Iterations per second: ", int(PROFILE_ITERATIONS / overall_duration));
print("Checksum: ", checksum);
