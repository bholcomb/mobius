func __copy_table(values) {
    var out = {}
    if (values == nil) {
        return out
    }
    for (var key, value in values) {
        out[key] = value
    }
    return out
}

func vec2(x, y) {
    return { x: x, y: y }
}

func rect(x, y, w, h) {
    return { x: x, y: y, w: w, h: h }
}

func color(r, g, b, a) {
    if (a == nil) {
        a = 1.0
    }
    return { r: r, g: g, b: b, a: a }
}

func color_to_u32(value) {
    var r = int(value.r * 255.0 + 0.5)
    var g = int(value.g * 255.0 + 0.5)
    var b = int(value.b * 255.0 + 0.5)
    var a = int(value.a * 255.0 + 0.5)
    return (a << 24) | (b << 16) | (g << 8) | r
}

func color_from_u32(value) {
    var r = ((value >> 0) & 0xFF) / 255.0
    var g = ((value >> 8) & 0xFF) / 255.0
    var b = ((value >> 16) & 0xFF) / 255.0
    var a = ((value >> 24) & 0xFF) / 255.0
    return color(r, g, b, a)
}

func rect_contains(r, px, py) {
    return px >= r.x && px < r.x + r.w && py >= r.y && py < r.y + r.h
}

func vertex(values) { return __copy_table(values) }
