enum Align {
    LEFT = 1 << 0,
    RIGHT = 1 << 1,
    TOP = 1 << 2,
    BOTTOM = 1 << 3,
    HCENTER = (1 << 0) | (1 << 1),
    VCENTER = (1 << 2) | (1 << 3),
    CENTER = ((1 << 0) | (1 << 1)) | ((1 << 2) | (1 << 3)),
    DEFAULT = (1 << 0) | ((1 << 2) | (1 << 3))
}

enum CornerFlags {
    NONE = 0,
    LL = 1 << 0,
    LR = 1 << 1,
    UR = 1 << 2,
    UL = 1 << 3,
    TOP = (1 << 3) | (1 << 2),
    BOTTOM = (1 << 0) | (1 << 1),
    LEFT = (1 << 0) | (1 << 3),
    RIGHT = (1 << 1) | (1 << 2),
    ALL = (1 << 0) | (1 << 1) | (1 << 2) | (1 << 3)
}

