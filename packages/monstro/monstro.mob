    CHILD_MENU = 1 << 26,
    DEFAULT = (1 << 0) | (1 << 1) | (1 << 3) | (1 << 5) | (1 << 10) | (1 << 11) | (1 << 12) | (1 << 13) | (1 << 16) | (1 << 14) | (1 << 21),
    ROOT_DEFAULT = (1 << 2) | (1 << 13) | (1 << 20)
}

