func __copy_table(values) {
    var out = {}
    if (values == nil) {
        return out
    }
    for (var key, value in values) {
        out[key] = value
    }
    return out
}

func color(r, g, b, a) {
    return { r: r, g: g, b: b, a: a }
}

func rect2d(x, y, width, height) {
    return { x: x, y: y, width: width, height: height }
}

func viewport(x, y, width, height, min_depth, max_depth) {
    return {
        x: x,
        y: y,
        width: width,
        height: height,
        minDepth: min_depth,
        maxDepth: max_depth
    }
}

func message_callback_desc(values) { return __copy_table(values) }
func buffer_desc(values) { return __copy_table(values) }
