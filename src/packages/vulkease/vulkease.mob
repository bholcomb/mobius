func surface_win32(hwnd) {
    return {
        type: SurfaceType.WIN32,
        win32: { hwnd: hwnd }
    }
}

func surface_xlib(display, window) {
    return {
        type: SurfaceType.XLIB,
        xlib: {
            display: display,
            window: window
        }
    }
}

func surface_wayland(display, surface) {
    return {
        type: SurfaceType.WAYLAND,
        wayland: {
            display: display,
            surface: surface
        }
    }
}

func surface_cocoa(window) {
    return {
        type: SurfaceType.COCOA,
        cocoa: { window: window }
    }
}

func surface_android(native_window) {
    return {
        type: SurfaceType.ANDROID,
        android: { nativeWindow: native_window }
    }
}

enum Result {
    SUCCESS = 0,
    ERROR_OUT_OF_MEMORY = 1,
    ERROR_DEVICE_LOST = 2,
    ERROR_INVALID_PARAMETER = 3,
    ERROR_FEATURE_NOT_SUPPORTED = 4,
    ERROR_UNSUPPORTED = 5,
    ERROR_SHADER_COMPILATION_FAILED = 6,
    ERROR_SWAPCHAIN_OUT_OF_DATE = 7,
    ERROR_TRANSFER_FAILED = 8,
    ERROR_NOT_FOUND = 9,
    ERROR_NOT_INITIALIZED = 10,
    ERROR_TIMEOUT = 11,
    ERROR_UNKNOWN = 999
}

enum MessageSeverity {
    VERBOSE = 0,
    INFO = 1,
    WARNING = 2,
    ERROR = 3
}

enum QueryType {
    OCCLUSION = 0,
    TIMESTAMP = 1,
    PIPELINE_STATISTICS = 2
}

enum SurfaceType {
    WIN32 = 0,
    XLIB = 1,
    WAYLAND = 2,
    COCOA = 3,
    ANDROID = 4
}

enum DefaultSampler {
    NEAREST = 0,
    LINEAR = 1,
    ANISOTROPIC_4X = 2,
    ANISOTROPIC_16X = 3,
    SHADOW = 4,
    COUNT = 5
}
