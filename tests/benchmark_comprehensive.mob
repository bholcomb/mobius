// Comprehensive Mobius Performance Benchmark
// Arrays benchmark dense numeric storage.
// Tables benchmark hash-map usage with string keys.

print("=== Mobius Comprehensive Performance Benchmark ===\n");
print("Benchmark model: arrays = dense integer storage, tables = string-key hash maps\n");

// ============================================================================
// 1. Arithmetic Operations
// ============================================================================
func ns_to_sec(ns) {
    return float(ns) / 1000000000.0;
}

func benchmark_arithmetic() {
    print("1. Arithmetic Operations...");
    var start = clock();
    var result = 0;
    var i = 0;
    while (i < 1000000) {
        result = result + i * 2 - 1;
        result = result / 2;
        result = result % 1000;
        i = i + 1;
    }
    var duration_ns = clock() - start;
    var duration = ns_to_sec(duration_ns);
    print("   Time: ", duration, "s");
    print("   Ops/sec: ", int(1000000.0 / duration));
    return result;
}

// ============================================================================
// 2. Function Calls
// ============================================================================
func fibonacci(n) {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

func benchmark_function_calls() {
    print("\n2. Function Calls (Fibonacci)...");
    var start = clock();
    var result = 0;
    var i = 0;
    while (i < 10) {
        result = fibonacci(20);
        i = i + 1;
    }
    var duration = ns_to_sec(clock() - start);
    print("   Time: ", duration, "s");
    print("   Result: ", result);
    return result;
}

// ============================================================================
// 3. Array Operations (dense numeric storage)
// ============================================================================
func benchmark_arrays() {
    print("\n3. Array Operations (Dense Numeric Storage)...");
    var start = clock();

    var arr = array_create(10000);
    var i = 0;
    while (i < 10000) {
        arr[i] = i * 2;
        i = i + 1;
    }

    var sum = 0;
    i = 0;
    while (i < 10000) {
        sum = sum + arr[i];
        i = i + 1;
    }

    var duration = ns_to_sec(clock() - start);
    print("   Time: ", duration, "s");
    print("   Sum: ", sum);
    return sum;
}

// ============================================================================
// 4. Table Operations (hash map string keys)
// ============================================================================
func build_table_keys(count) {
    var keys = array_create(count);
    var i = 0;
    while (i < count) {
        keys:push(concat("key_", str(i)));
        i = i + 1;
    }
    return keys;
}

func benchmark_tables() {
    print("\n4. Table Operations (String-Key Hash Map)...");
    var keys = build_table_keys(5000);
    var start = clock();

    var tbl = {};
    var i = 0;
    while (i < 5000) {
        tbl[keys[i]] = i * 3;
        i = i + 1;
    }

    var sum = 0;
    i = 0;
    while (i < 5000) {
        sum = sum + tbl[keys[i]];
        i = i + 1;
    }

    var duration = ns_to_sec(clock() - start);
    print("   Time: ", duration, "s");
    print("   Sum: ", sum);
    return sum;
}

// ============================================================================
// 5. String Operations
// ============================================================================
func benchmark_strings() {
    print("\n5. String Operations...");
    var start = clock();
    
    var base = "Hello";
    var result = "";
    var i = 0;
    while (i < 1000) {
        result = concat(base, " World ", str(i));
        var len_result = len(result);
        var upper_result = upper(result);
        i = i + 1;
    }
    
    var duration = ns_to_sec(clock() - start);
    print("   Time: ", duration, "s");
    print("   Final length: ", len(result));
    return result;
}

// ============================================================================
// 6. Nested Loops
// ============================================================================
func benchmark_nested_loops() {
    print("\n6. Nested Loops...");
    var start = clock();
    
    var sum = 0;
    var i = 0;
    while (i < 500) {
        var j = 0;
        while (j < 500) {
            sum = sum + i * j;
            j = j + 1;
        }
        i = i + 1;
    }
    
    var duration = ns_to_sec(clock() - start);
    print("   Time: ", duration, "s");
    print("   Sum: ", sum);
    return sum;
}

// ============================================================================
// 7. Object Creation/Destruction
// ============================================================================
func benchmark_object_lifecycle() {
    print("\n7. Object Creation/Destruction...");
    var start = clock();
    
    var i = 0;
    while (i < 10000) {
        var temp_array = [1, 2, 3, 4, 5];
        var temp_table = {a: 1, b: 2, c: 3};
        var temp_str = concat("temp", str(i));
        i = i + 1;
    }
    
    var duration = ns_to_sec(clock() - start);
    print("   Time: ", duration, "s");
    print("   Objects created: 30000");
    return i;
}

// ============================================================================
// 8. Mixed Workload
// ============================================================================
func benchmark_mixed() {
    print("\n8. Mixed Workload...");
    var start = clock();
    
    var data = array_create(1000);
    var i = 0;
    while (i < 1000) {
        var record = {
            id: i,
            value: i * 2,
            name: concat("item_", str(i))
        };
        data:push(record);
        i = i + 1;
    }
    
    // Process the data
    var total = 0;
    i = 0;
    while (i < 1000) {
        var record = data:get(i);
        total = total + record.value;
        i = i + 1;
    }
    
    var duration = ns_to_sec(clock() - start);
    print("   Time: ", duration, "s");
    print("   Total: ", total);
    return total;
}

// ============================================================================
// Run All Benchmarks
// ============================================================================
print("Starting benchmarks...\n");
var overall_start = clock();

benchmark_arithmetic();
benchmark_function_calls();
benchmark_arrays();
benchmark_tables();
benchmark_strings();
benchmark_nested_loops();
benchmark_object_lifecycle();
benchmark_mixed();

var overall_duration = ns_to_sec(clock() - overall_start);

print("\n=== Overall Results ===");
print("Total time: ", overall_duration, "s");
print("Benchmark complete!");
