// Comprehensive Table Usage Examples for Mobius
print("=== Mobius Table Examples ===");

// 1. BASIC TABLE CREATION AND ACCESS
print("1. Basic Table Creation and Access");

// Empty table
var empty = {};
print("Empty table:", empty);

// Table with identifier keys
var person = {name: "Alice", age: 30, occupation: "Engineer"};
print("Person:", person);

// Array-style initialization (0-based indexing)
var colors = {"red", "green", "blue", "yellow"};
print("Colors:", colors);

// 2. TABLE ACCESS METHODS
print("2. Table Access Methods");

// Dot notation (for identifier keys)
print("person.name:", person.name);
print("person.age:", person.age);

// Bracket notation (for any key type)
var name_val = person["name"];
print("person name via bracket:", name_val);
print("colors[0]:", colors[0]);
print("colors[2]:", colors[2]);

// 3. DYNAMIC TABLE MODIFICATION
print("3. Dynamic Table Modification");

// Adding new entries using assignment syntax
person["city"] = "New York";
colors[4] = "purple";

print("After additions - person:", person);
print("After additions - colors:", colors);

// 4. TABLE BUILT-IN FUNCTIONS
print("4. Table Built-in Functions");

var data = {a: 1, b: 2, c: 3};
print("Original data:", data);

// assignment syntax
data["d"] = 4;
print("After assignment:", data);

// table_has_key
print("Has key 'a':", data:has_key("a"));
print("Has key 'z':", data:has_key("z"));

// table_size
print("Table size:", data:size());

// table_remove
var removed = data:remove("b");
print("Removed value:", removed);
print("After removing 'b':", data);

// 5. TABLE ITERATION WITH PAIRS
print("5. Table Iteration with pairs()");

var inventory = {apples: 10, bananas: 5, oranges: 8};
print("Inventory:", inventory);

var all_pairs = inventory:pairs();
print("Using pairs() to iterate:");
for (var i = 0; i < size(all_pairs); i = i + 1) {
    var pair = all_pairs[i];
    if (pair != nil) {
        print("Item:", pair[0], "Count:", pair[1]);
    }
}

// 6. METATABLE BASICS
print("6. Metatable Basics");

var obj = {value: 42};
var meta = {type: "custom_object"};

setmetatable(obj, meta);
var retrieved = getmetatable(obj);
print("Object:", obj);
print("Retrieved metatable:", retrieved);

print("=== Table Examples Complete! ===");
