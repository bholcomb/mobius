// Test built-in table functions
print("=== Testing Table Built-in Functions ===");

// Create a test table
var data = {name: "Alice", age: 30};
print("Initial table:", data);

// Test direct assignment
data["city"] = "New York";
print("After assignment:", data);

// Test table_has_key
print("Has 'name':", data:has_key("name"));
print("Has 'country':", data:has_key("country"));

// Test table_size
print("Table size:", data:size());

// Test table_remove
var removed = data:remove("age");
print("Removed value:", removed);
print("After table_remove:", data);
print("New size:", data:size());

// Test metatable functions
var meta = {name: "__meta"};

print("Setting metatable...");
setmetatable(data, meta);
var retrieved_meta = getmetatable(data);
print("Retrieved metatable:", retrieved_meta);

print("=== All table function tests completed! ===");