// Test optional type annotations on function parameters and return values

print("=== Function Type Annotation Tests ===")

// 1. Fully annotated function (int params, int return)
func add_ints(a: int, b: int): int {
    return a + b
}

var r1 = add_ints(10, 20)
if (r1 == 30) {
    print("1. Fully annotated int function: PASS")
} else {
    print("1. FAIL: expected 30, got " + r1)
}

// 2. Float annotations
func add_floats(a: float, b: float): float {
    return a + b
}

var r2 = add_floats(1.5, 2.5)
if (r2 == 4.0) {
    print("2. Fully annotated float function: PASS")
} else {
    print("2. FAIL: expected 4.0, got " + r2)
}

// 3. String annotations
func greet(name: string): string {
    return "Hello, " + name
}

var r3 = greet("Mobius")
if (r3 == "Hello, Mobius") {
    print("3. String annotated function: PASS")
} else {
    print("3. FAIL: expected 'Hello, Mobius', got " + r3)
}

// 4. Mixed annotations (some params annotated, some not)
func mixed(a: int, b) {
    return a + b
}

var r4 = mixed(10, 20)
if (r4 == 30) {
    print("4. Mixed annotation function: PASS")
} else {
    print("4. FAIL: expected 30, got " + r4)
}

// 5. Return type only, no param annotations
func pi_value(): float {
    return 3.14159
}

var r5 = pi_value()
if (r5 > 3.14 && r5 < 3.15) {
    print("5. Return type only annotation: PASS")
} else {
    print("5. FAIL: expected ~3.14159, got " + r5)
}

// 6. No annotations at all (backward compatibility)
func plain_add(a, b) {
    return a + b
}

var r6 = plain_add(5, 7)
if (r6 == 12) {
    print("6. No annotations (backward compat): PASS")
} else {
    print("6. FAIL: expected 12, got " + r6)
}

// 7. Bool annotations
func is_positive(n: int): bool {
    return n > 0
}

if (is_positive(5) == true && is_positive(-3) == false) {
    print("7. Bool return annotation: PASS")
} else {
    print("7. FAIL")
}

// 8. Recursive function with annotations (fibonacci)
func fibonacci(n: int): int {
    if (n <= 1) return n
    return fibonacci(n - 1) + fibonacci(n - 2)
}

var fib10 = fibonacci(10)
if (fib10 == 55) {
    print("8. Annotated recursive fibonacci: PASS")
} else {
    print("8. FAIL: expected 55, got " + fib10)
}

// 9. Recursive function with annotations (factorial)
func factorial(n: int): int {
    if (n <= 1) return 1
    return n * factorial(n - 1)
}

var fact6 = factorial(6)
if (fact6 == 720) {
    print("9. Annotated recursive factorial: PASS")
} else {
    print("9. FAIL: expected 720, got " + fact6)
}

// 10. Function expression with annotations
var doubler = func(x: int): int {
    return x * 2
}

var r10 = doubler(21)
if (r10 == 42) {
    print("10. Annotated function expression: PASS")
} else {
    print("10. FAIL: expected 42, got " + r10)
}

// 11. Function expression with partial annotations
var formatter = func(prefix: string, value): string {
    return prefix + str(value)
}

var r11 = formatter("count=", 42)
if (r11 == "count=42") {
    print("11. Partially annotated func expression: PASS")
} else {
    print("11. FAIL: expected 'count=42', got " + r11)
}

// 12. Array return type
func make_pair(a: int, b: int): array {
    return [a, b]
}

var r12 = make_pair(1, 2)
if (r12[0] == 1 && r12[1] == 2) {
    print("12. Array return type annotation: PASS")
} else {
    print("12. FAIL")
}

// 13. Table return type
func make_point(x: float, y: float): table {
    return {x: x, y: y}
}

var r13 = make_point(3.0, 4.0)
if (r13.x == 3.0 && r13.y == 4.0) {
    print("13. Table return type annotation: PASS")
} else {
    print("13. FAIL")
}

// 14. Type aliases (int vs integer vs int64 should all work)
func alias_test_int(a: int): int { return a + 1 }
func alias_test_integer(a: integer): integer { return a + 2 }
func alias_test_int64(a: int64): int64 { return a + 3 }

if (alias_test_int(10) == 11 && alias_test_integer(10) == 12 && alias_test_int64(10) == 13) {
    print("14. Type name aliases (int/integer/int64): PASS")
} else {
    print("14. FAIL")
}

// 15. Float aliases (float vs float64)
func alias_float(a: float): float { return a + 0.1 }
func alias_float64(a: float64): float64 { return a + 0.2 }

var rf1 = alias_float(1.0)
var rf2 = alias_float64(1.0)
if (rf1 > 1.09 && rf1 < 1.11 && rf2 > 1.19 && rf2 < 1.21) {
    print("15. Type name aliases (float/float64): PASS")
} else {
    print("15. FAIL")
}

// 16. Bool alias (bool vs boolean)
func alias_bool(x: bool): bool { return !x }
func alias_boolean(x: boolean): boolean { return !x }

if (alias_bool(true) == false && alias_boolean(false) == true) {
    print("16. Type name aliases (bool/boolean): PASS")
} else {
    print("16. FAIL")
}

// 17. Nil return type
func returns_nil(): nil {
    return nil
}

var r17 = returns_nil()
if (r17 == nil) {
    print("17. Nil return type annotation: PASS")
} else {
    print("17. FAIL")
}

// 18. Higher-order function with annotated callback
func apply(f: function, x: int): int {
    return f(x)
}

func triple(n: int): int {
    return n * 3
}

var r18 = apply(triple, 7)
if (r18 == 21) {
    print("18. Higher-order with function annotation: PASS")
} else {
    print("18. FAIL: expected 21, got " + r18)
}

// 19. Annotated closure
func make_adder(n: int): function {
    return func(x: int): int {
        return x + n
    }
}

var add5 = make_adder(5)
var r19 = add5(10)
if (r19 == 15) {
    print("19. Annotated closure: PASS")
} else {
    print("19. FAIL: expected 15, got " + r19)
}

print("=== All Function Type Annotation Tests Completed ===")
