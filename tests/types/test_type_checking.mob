// Test type checking and conversion
print("=== Basic Type Annotations ===");
var x: int64 = 42;
var y: float64 = 3.14;
var z: uint64 = 255;

print("x (int64):", x);
print("y (float):", y);
print("z (uint64):", z);

print("\n=== Type Conversion Tests ===");
var a: int64 = 3.8;  // Should convert float to int64
var b: float64 = 100;  // Should convert int to float

print("a (float->int64):", a);
print("b (int->float):", b);

print("\n=== Mixed arithmetic ===");
var result: float64 = x + y;
print("x + y =", result);

print("\n=== Testing integer sizes ===");
var signed: int64 = 5000000000;
var unsigned: uint64 = 18000000000000000000;

print("signed (int64):", signed);
print("unsigned (uint64):", unsigned);
