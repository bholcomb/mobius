// Comprehensive Standard Library Test

print("=== Mobius Standard Library Test ===");

// Core functions
print("\n=== Core Functions ===");
var x = 42;
var y = 3.14;
print("x =", x, "typeof:", typeof(x));
print("y =", y, "typeof:", typeof(y));
print("str(x) =", str(x));
print("int(y) =", int(y));
print("float(x) =", float(x));

// Math functions
print("\n=== Math Functions ===");
print("abs(-5) =", abs(-5));
print("abs(-3.14) =", abs(-3.14));
print("min(1, 2, 3) =", min(1, 2, 3));
print("max(1, 2, 3) =", max(1, 2, 3));
print("pow(2, 3) =", pow(2, 3));
print("sqrt(16) =", sqrt(16));
print("floor(3.7) =", floor(3.7));
print("ceil(3.2) =", ceil(3.2));
print("round(3.6) =", round(3.6));

// String functions
print("\n=== String Functions ===");
var text = "Hello World";
print("text =", text);
print("len(text) =", len(text));
print("upper(text) =", upper(text));
print("lower(text) =", lower(text));
print("substr(text, 0, 5) =", substr(text, 0, 5));
var world = "World";
var xyz = "xyz";
print("contains(text, world) =", contains(text, world));
print("contains(text, xyz) =", contains(text, xyz));
var hello = "Hello";
var space = " ";
var mobius = "Mobius";
print("concat(hello, space, mobius) =", concat(hello, space, mobius));

// Utility functions
print("\n=== Utility Functions ===");
print("random() =", random());
print("random(10) =", random(10));
print("random(5, 15) =", random(5, 15));
print("time() =", time());
print("clock() =", clock());

print("\n=== Standard Library Test Complete ===");
