// Test order of operations for arithmetic and logical expressions
// This test verifies that operators are evaluated in the correct precedence order

print("=== Testing Order of Operations ===");

// Test 1: Basic arithmetic precedence
// Multiplication and division before addition and subtraction
print("Testing basic arithmetic precedence...");

var result1 = 2 + 3 * 4;        // Should be 2 + 12 = 14, not 5 * 4 = 20
var result2 = 10 - 6 / 2;       // Should be 10 - 3 = 7, not 4 / 2 = 2
var result3 = 2 * 3 + 4 * 5;    // Should be 6 + 20 = 26
var result4 = 20 / 4 - 2 * 3;   // Should be 5 - 6 = -1

if (result1 == 14 && result2 == 7 && result3 == 26 && result4 == -1) {
    print("✅ Basic arithmetic precedence test passed");
} else {
    print("❌ Basic arithmetic precedence test failed:");
    print("  2 + 3 * 4 = " + result1 + " (expected 14) - " + (result1 == 14));
    print("  10 - 6 / 2 = " + result2 + " (expected 7) - " + (result2 == 7));
    print("  2 * 3 + 4 * 5 = " + result3 + " (expected 26) - " + (result3 == 26));
    print("  20 / 4 - 2 * 3 = " + result4 + " (expected -1) - " + (result4 == -1));
}

// Test 2: Parentheses override precedence
print("Testing parentheses precedence...");

var paren1 = (2 + 3) * 4;       // Should be 5 * 4 = 20
var paren2 = (10 - 6) / 2;      // Should be 4 / 2 = 2
var paren3 = 2 * (3 + 4) * 5;   // Should be 2 * 7 * 5 = 70
var paren4 = (20 / 4 - 2) * 3;  // Should be (5 - 2) * 3 = 9

if (paren1 == 20 && paren2 == 2 && paren3 == 70 && paren4 == 9) {
    print("✅ Parentheses precedence test passed");
} else {
    print("❌ Parentheses precedence test failed:");
    print("  (2 + 3) * 4 = " + paren1 + " (expected 20) - " + (paren1 == 20));
    print("  (10 - 6) / 2 = " + paren2 + " (expected 2) - " + (paren2 == 2));
    print("  2 * (3 + 4) * 5 = " + paren3 + " (expected 70) - " + (paren3 == 70));
    print("  (20 / 4 - 2) * 3 = " + paren4 + " (expected 9) - " + (paren4 == 9));
}

// Test 3: Comparison operators
print("Testing comparison operator precedence...");

// Arithmetic should be evaluated before comparisons
var comp1 = 2 + 3 > 4;          // Should be 5 > 4 = true
var comp2 = 10 - 6 < 2 * 3;     // Should be 4 < 6 = true  
var comp3 = 3 * 4 == 6 + 6;     // Should be 12 == 12 = true
var comp4 = 15 / 3 != 2 + 2;    // Should be 5 != 4 = true

if (comp1 == true && comp2 == true && comp3 == true && comp4 == true) {
    print("✅ Comparison operator precedence test passed");
} else {
    print("❌ Comparison operator precedence test failed:");
    print("  2 + 3 > 4 = " + comp1 + " (expected true) - " + (comp1 == true));
    print("  10 - 6 < 2 * 3 = " + comp2 + " (expected true) - " + (comp2 == true));
    print("  3 * 4 == 6 + 6 = " + comp3 + " (expected true) - " + (comp3 == true));
    print("  15 / 3 != 2 + 2 = " + comp4 + " (expected true) - " + (comp4 == true));
}

// Test 4: Logical AND precedence
print("Testing logical AND precedence...");

// AND should have higher precedence than OR
// Comparisons should be evaluated before logical operators
var and1 = true && false || true;   // Should be (true && false) || true = false || true = true
var and2 = false || true && false;  // Should be false || (true && false) = false || false = false
var and3 = 2 > 1 && 3 < 5;         // Should be true && true = true
var and4 = 1 > 2 && 3 < 5;         // Should be false && true = false

print("✅ Logical AND precedence test results:");
print("  true && false || true = " + and1 + " (expected true)");
print("  false || true && false = " + and2 + " (expected false)");
print("  2 > 1 && 3 < 5 = " + and3 + " (expected true)");
print("  1 > 2 && 3 < 5 = " + and4 + " (expected false)");

// Test 5: Logical OR precedence
print("Testing logical OR precedence...");

var or1 = false || true && false || true;  // Should be false || (true && false) || true = false || false || true = true
var or2 = true || false && true;           // Should be true || (false && true) = true || false = true
var or3 = 1 > 2 || 3 > 1 && 5 > 4;       // Should be false || (true && true) = false || true = true
var or4 = 2 > 3 || 4 > 5 || 1 < 2;       // Should be false || false || true = true

print("✅ Logical OR precedence test results:");
print("  false || true && false || true = " + or1 + " (expected true)");
print("  true || false && true = " + or2 + " (expected true)");
print("  1 > 2 || 3 > 1 && 5 > 4 = " + or3 + " (expected true)");
print("  2 > 3 || 4 > 5 || 1 < 2 = " + or4 + " (expected true)");

// Test 6: Complex mixed expressions
print("Testing complex mixed expressions...");

var complex1 = 2 + 3 * 4 > 10 && 5 - 2 < 4;    // Should be 14 > 10 && 3 < 4 = true && true = true
var complex2 = 1 + 2 * 3 == 7 || 4 / 2 != 2;   // Should be 7 == 7 || 2 != 2 = true || false = true
var complex3 = (2 + 3) * 2 > 9 && 10 / 2 == 5; // Should be 10 > 9 && 5 == 5 = true && true = true
var complex4 = 3 * 2 + 1 < 8 || 4 - 1 > 5;     // Should be 7 < 8 || 3 > 5 = true || false = true

print("✅ Complex mixed expressions test results:");
print("  2 + 3 * 4 > 10 && 5 - 2 < 4 = " + complex1 + " (expected true)");
print("  1 + 2 * 3 == 7 || 4 / 2 != 2 = " + complex2 + " (expected true)");
print("  (2 + 3) * 2 > 9 && 10 / 2 == 5 = " + complex3 + " (expected true)");
print("  3 * 2 + 1 < 8 || 4 - 1 > 5 = " + complex4 + " (expected true)");

// Test 7: Negation precedence
print("Testing negation precedence...");

var neg1 = !true && false;      // Should be false && false = false
var neg2 = !false || false;     // Should be true || false = true
var neg3 = !(true && false);    // Should be !false = true
var neg4 = !true || !false;     // Should be false || true = true

print("✅ Negation precedence test results:");
print("  !true && false = " + neg1 + " (expected false)");
print("  !false || false = " + neg2 + " (expected true)");
print("  !(true && false) = " + neg3 + " (expected true)");
print("  !true || !false = " + neg4 + " (expected true)");

// Test 8: Unary minus precedence
print("Testing unary minus precedence...");

var minus1 = -2 + 3;            // Should be (-2) + 3 = 1
var minus2 = -(2 + 3);          // Should be -(5) = -5
var minus3 = -2 * 3;            // Should be (-2) * 3 = -6
var minus4 = 2 * -3;            // Should be 2 * (-3) = -6

print("✅ Unary minus precedence test results:");
print("  -2 + 3 = " + minus1 + " (expected 1)");
print("  -(2 + 3) = " + minus2 + " (expected -5)");
print("  -2 * 3 = " + minus3 + " (expected -6)");
print("  2 * -3 = " + minus4 + " (expected -6)");

print("=== Order of Operations Tests Completed ===");
