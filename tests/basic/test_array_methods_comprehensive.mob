// Comprehensive test of all array methods via : syntax
print("=== Array Methods Comprehensive ===")

// array_create with required capacity
var a = array_create(5)
if (a:size() != 0) { print("FAIL: empty array_create length"); exit(1) }

// array_create with fill_value
var b = array_create(4, 0)
if (b:size() != 4) { print("FAIL: fill array length, got", b:size()); exit(1) }
if (b[0] != 0 || b[3] != 0) { print("FAIL: fill values"); exit(1) }

var c = array_create(3, "x")
if (c:size() != 3) { print("FAIL: fill string length"); exit(1) }
if (c[0] != "x" || c[2] != "x") { print("FAIL: fill string values"); exit(1) }

// push
var arr = []
arr:push(10)
arr:push(20)
arr:push(30)
if (arr:size() != 3) { print("FAIL: push/length"); exit(1) }

// get
if (arr:get(0) != 10) { print("FAIL: get(0)"); exit(1) }
if (arr:get(1) != 20) { print("FAIL: get(1)"); exit(1) }
if (arr:get(2) != 30) { print("FAIL: get(2)"); exit(1) }

// set
arr:set(1, 99)
if (arr[1] != 99) { print("FAIL: set"); exit(1) }
arr:set(1, 20)

// pop
var popped = arr:pop()
if (popped != 30) { print("FAIL: pop value, got", popped); exit(1) }
if (arr:size() != 2) { print("FAIL: pop length"); exit(1) }
arr:push(30)

// find
if (arr:find(20) != 1) { print("FAIL: find existing"); exit(1) }
if (arr:find(999) != -1) { print("FAIL: find missing"); exit(1) }

// slice
var s = arr:slice(0, 2)
if (s:size() != 2) { print("FAIL: slice length"); exit(1) }
if (s[0] != 10 || s[1] != 20) { print("FAIL: slice values"); exit(1) }

// concat
var cat = [1, 2]:concat([3, 4])
if (cat:size() != 4) { print("FAIL: concat length"); exit(1) }
if (cat[0] != 1 || cat[3] != 4) { print("FAIL: concat values"); exit(1) }

// reverse
var rev = [5, 4, 3, 2, 1]
rev:reverse()
if (rev[0] != 1 || rev[4] != 5) { print("FAIL: reverse"); exit(1) }

// sort (default)
var nums = [3, 1, 4, 1, 5, 9]
nums:sort()
if (nums[0] != 1 || nums[1] != 1 || nums[5] != 9) { print("FAIL: sort default"); exit(1) }

// sort (comparator - descending)
nums:sort(func(a, b) { return a > b })
if (nums[0] != 9 || nums[5] != 1) { print("FAIL: sort comparator"); exit(1) }

// map
var doubled = [1, 2, 3]:map(func(x, i) { return x * 2 })
if (doubled:size() != 3) { print("FAIL: map length"); exit(1) }
if (doubled[0] != 2 || doubled[1] != 4 || doubled[2] != 6) { print("FAIL: map values"); exit(1) }

// map uses index parameter
var indexed = [10, 20, 30]:map(func(x, i) { return i })
if (indexed[0] != 0 || indexed[1] != 1 || indexed[2] != 2) { print("FAIL: map index param"); exit(1) }

// filter
var evens = [1, 2, 3, 4, 5, 6]:filter(func(x, i) { return x % 2 == 0 })
if (evens:size() != 3) { print("FAIL: filter length"); exit(1) }
if (evens[0] != 2 || evens[1] != 4 || evens[2] != 6) { print("FAIL: filter values"); exit(1) }

// reduce
var total = [1, 2, 3, 4]:reduce(func(acc, x) { return acc + x }, 0)
if (total != 10) { print("FAIL: reduce, got", total); exit(1) }

// reduce with string accumulator
var joined = ["a", "b", "c"]:reduce(func(acc, x) { return acc + x }, "")
if (joined != "abc") { print("FAIL: reduce string, got", joined); exit(1) }

// foreach (side effects)
var sum = 0
[10, 20, 30]:foreach(func(x, i) { sum += x })
if (sum != 60) { print("FAIL: foreach sum, got", sum); exit(1) }

// any
if (![1, 2, 100]:any(func(x) { return x > 50 })) { print("FAIL: any true"); exit(1) }
if ([1, 2, 3]:any(func(x) { return x > 50 })) { print("FAIL: any false"); exit(1) }

// all
if (![2, 4, 6]:all(func(x) { return x % 2 == 0 })) { print("FAIL: all true"); exit(1) }
if ([2, 4, 5]:all(func(x) { return x % 2 == 0 })) { print("FAIL: all false"); exit(1) }

// empty array edge cases
var empty = []
if (empty:size() != 0) { print("FAIL: empty length"); exit(1) }
if (empty:find(1) != -1) { print("FAIL: empty find"); exit(1) }
var mapped_empty = empty:map(func(x, i) { return x })
if (mapped_empty:size() != 0) { print("FAIL: empty map"); exit(1) }
var filtered_empty = empty:filter(func(x, i) { return true })
if (filtered_empty:size() != 0) { print("FAIL: empty filter"); exit(1) }
var reduced_empty = empty:reduce(func(acc, x) { return acc + x }, 42)
if (reduced_empty != 42) { print("FAIL: empty reduce, got", reduced_empty); exit(1) }
if (empty:any(func(x) { return true })) { print("FAIL: empty any"); exit(1) }
if (!empty:all(func(x) { return false })) { print("FAIL: empty all"); exit(1) }

print("=== All array methods tests passed! ===")
