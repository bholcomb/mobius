// Comprehensive test of all string standard library functions
print("=== String Functions Comprehensive ===")

// split
var parts = split("hello world foo", " ")
if (parts:length() != 3) { print("FAIL: split length, got", parts:length()); exit(1) }
if (parts[0] != "hello") { print("FAIL: split[0]"); exit(1) }
if (parts[1] != "world") { print("FAIL: split[1]"); exit(1) }
if (parts[2] != "foo") { print("FAIL: split[2]"); exit(1) }

// split with multi-char delimiter
var csv = split("a,,b,,c", ",,")
if (csv:length() != 3) { print("FAIL: split multi-char length"); exit(1) }
if (csv[0] != "a" || csv[2] != "c") { print("FAIL: split multi-char values"); exit(1) }

// split single element (no delimiter found)
var single = split("hello", ",")
if (single:length() != 1) { print("FAIL: split no match length"); exit(1) }
if (single[0] != "hello") { print("FAIL: split no match value"); exit(1) }

// join
var j = join(["a", "b", "c"], "-")
if (j != "a-b-c") { print("FAIL: join, got", j); exit(1) }

// join with empty delimiter
var j2 = join(["x", "y", "z"], "")
if (j2 != "xyz") { print("FAIL: join empty delim, got", j2); exit(1) }

// join single element
var j3 = join(["only"], ",")
if (j3 != "only") { print("FAIL: join single, got", j3); exit(1) }

// trim
if (trim("  hello  ") != "hello") { print("FAIL: trim both"); exit(1) }
if (trim("hello") != "hello") { print("FAIL: trim none"); exit(1) }
if (trim("  ") != "") { print("FAIL: trim all whitespace"); exit(1) }
if (trim("\t\nhello\t\n") != "hello") { print("FAIL: trim tabs/newlines"); exit(1) }

// startswith
if (!startswith("hello world", "hello")) { print("FAIL: startswith true"); exit(1) }
if (startswith("hello world", "world")) { print("FAIL: startswith false"); exit(1) }
if (!startswith("hello", "hello")) { print("FAIL: startswith exact"); exit(1) }
if (!startswith("hello", "")) { print("FAIL: startswith empty"); exit(1) }

// endswith
if (!endswith("hello world", "world")) { print("FAIL: endswith true"); exit(1) }
if (endswith("hello world", "hello")) { print("FAIL: endswith false"); exit(1) }
if (!endswith("hello", "hello")) { print("FAIL: endswith exact"); exit(1) }
if (!endswith("hello", "")) { print("FAIL: endswith empty"); exit(1) }

// replace
var rep = replace("hello world hello", "hello", "hi")
if (rep != "hi world hi") { print("FAIL: replace, got", rep); exit(1) }

// replace no match
var rep2 = replace("hello", "xyz", "abc")
if (rep2 != "hello") { print("FAIL: replace no match, got", rep2); exit(1) }

// find (substring index)
var fi = find("hello world", "world")
if (fi != 6) { print("FAIL: find, got", fi); exit(1) }

var fi2 = find("hello world", "xyz")
if (fi2 != -1) { print("FAIL: find missing, got", fi2); exit(1) }

var fi3 = find("hello", "hello")
if (fi3 != 0) { print("FAIL: find at start, got", fi3); exit(1) }

// repeat
var r = repeat("ab", 3)
if (r != "ababab") { print("FAIL: repeat, got", r); exit(1) }

var r2 = repeat("x", 0)
if (r2 != "") { print("FAIL: repeat 0, got", r2); exit(1) }

var r3 = repeat("x", 1)
if (r3 != "x") { print("FAIL: repeat 1, got", r3); exit(1) }

// existing string functions still work
if (len("hello") != 5) { print("FAIL: len"); exit(1) }
if (upper("hello") != "HELLO") { print("FAIL: upper"); exit(1) }
if (lower("HELLO") != "hello") { print("FAIL: lower"); exit(1) }
if (substr("hello world", 6, 5) != "world") { print("FAIL: substr"); exit(1) }
if (!contains("hello world", "world")) { print("FAIL: contains"); exit(1) }

print("=== All string function tests passed! ===")
