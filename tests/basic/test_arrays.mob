// Basic array test to verify our implementation
print("=== Array Implementation Test ===");

// Test array creation and basic operations
var arr = array_create(5);
print("Created array with capacity 5");

// Test push
arr:push(10);
arr:push(20);
arr:push(30);
print("Pushed 3 elements");

// Test length
var len = arr:size();
print("Array length: " + len);

// Test get
var first = arr:get(0);
var second = arr:get(1);
var third = arr:get(2);
print("Elements: " + first + ", " + second + ", " + third);

// Test set
arr:set(1, 99);
var modified = arr:get(1);
print("After setting index 1 to 99: " + modified);

// Test pop
var popped = arr:pop();
print("Popped element: " + popped);
print("New length: " + arr:size());

print("=== Array Test Complete ===");
