// Test method calls on inline literals and chaining
print("=== Method Chaining and Inline Literals ===")

// Method on inline array literal
var mapped = [1, 2, 3]:map(func(x, i) { return x + 1 })
if (mapped[0] != 2 || mapped[2] != 4) { print("FAIL: inline map"); exit(1) }

// Chained methods
var result = [5, 3, 1, 4, 2]:filter(func(x, i) { return x > 2 })
if (result:size() != 3) { print("FAIL: filter chain length"); exit(1) }

// Map then reduce
var sum = [1, 2, 3]:map(func(x, i) { return x * x }):reduce(func(acc, x) { return acc + x }, 0)
if (sum != 14) { print("FAIL: map-reduce chain, got", sum); exit(1) }

// Find on inline
var idx = [10, 20, 30]:find(20)
if (idx != 1) { print("FAIL: inline find"); exit(1) }

// Length on inline
var l = [1, 2, 3, 4, 5]:size()
if (l != 5) { print("FAIL: inline length"); exit(1) }

// Slice on inline
var sl = [10, 20, 30, 40, 50]:slice(1, 4)
if (sl:size() != 3) { print("FAIL: inline slice length"); exit(1) }
if (sl[0] != 20 || sl[2] != 40) { print("FAIL: inline slice values"); exit(1) }

// Concat on inline
var c = [1, 2]:concat([3, 4])
if (c:size() != 4) { print("FAIL: inline concat"); exit(1) }

// Any/all on inline
if (![1, 2, 100]:any(func(x) { return x == 100 })) { print("FAIL: inline any"); exit(1) }
if (![2, 4, 6]:all(func(x) { return x % 2 == 0 })) { print("FAIL: inline all"); exit(1) }

// Table method on inline
if ({a: 1, b: 2, c: 3}:size() != 3) { print("FAIL: inline table size"); exit(1) }
if (!{key: "val"}:has_key("key")) { print("FAIL: inline table has_key"); exit(1) }

// Methods in expressions
var arr = [1, 2, 3]
if (arr:size() + 10 != 13) { print("FAIL: method in expression"); exit(1) }
if (arr:find(2) * 5 != 5) { print("FAIL: method result arithmetic"); exit(1) }

// Method result as function argument
print("length is", [1, 2, 3]:size())

// Method call inside if condition
if (![1, 2, 3]:any(func(x) { return x == 2 })) {
    print("FAIL: method in if condition"); exit(1)
}

// Method call in variable declaration
var filtered = [1, 2, 3, 4, 5]:filter(func(x, i) { return x > 3 })
if (filtered:size() != 2) { print("FAIL: method in var decl"); exit(1) }

print("=== All method chaining tests passed! ===")
