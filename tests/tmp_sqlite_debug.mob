import "sqlite"

print("phase 1")
var db = sqlite.open(":memory:")
print("phase 2")
db:exec("create table items (id integer primary key, name text)")
print("phase 3")
db:exec("insert into items (name) values (?)", ["alpha"])
print("phase 4")
var rows = db:query("select id, name from items")
print("phase 5", len(rows))
var stmt = db:prepare("select id, name from items")
print("phase 6")
var row = stmt:step()
print("phase 7", row.name)
stmt:finalize()
print("phase 8")
db:close()
print("phase 9")
