import "os"

var pass_count = 0
var fail_count = 0

func assert_test(name, cond) {
    if (cond) {
        pass_count = pass_count + 1
        print("PASS: " + name)
    } else {
        fail_count = fail_count + 1
        print("FAIL: " + name)
    }
}

var repo_root = os.getcwd()
var mobius_bin = os.join(repo_root, "bin", "mobius")
var pack_tool = os.join(repo_root, "tools", "pack_module.mob")
var install_tool = os.join(repo_root, "tools", "install_module.mob")
var package_source = os.join(repo_root, "packages", "vulkease")

var workspace = os.join(os.tmpdir(), "mobius_vulkease_pkg_" + str(os.getpid()))
var modules_root = os.join(workspace, "modules")
var archive_path = os.join(workspace, "vulkease.mz")
var run_script = os.join(workspace, "run.mob")

assert_test("vulkease package staged", os.is_dir(package_source))
assert_test("create workspace", os.mkdirp(workspace))
assert_test("write run script", writefile(run_script,
    "import \"vulkease\"\n" +
    "func ensure(cond) { if (!cond) { exit(1) } }\n" +
    "ensure(typeof(vulkease.Result) == \"enum\")\n" +
    "ensure(typeof(vulkease.MessageSeverity) == \"enum\")\n" +
    "ensure(typeof(vulkease.QueryType) == \"enum\")\n" +
    "ensure(typeof(vulkease.SurfaceType) == \"enum\")\n" +
    "ensure(typeof(vulkease.DefaultSampler) == \"enum\")\n" +
    "var c = vulkease.color(1.0, 0.5, 0.25, 1.0)\n" +
    "ensure(c.r == 1.0 && c.g == 0.5 && c.b == 0.25 && c.a == 1.0)\n" +
    "var vp = vulkease.viewport(0, 0, 640, 480, 0.0, 1.0)\n" +
    "ensure(vp.width == 640 && vp.height == 480)\n" +
    "var surf = vulkease.surface_xlib(1, 2)\n" +
    "ensure(surf.type == vulkease.SurfaceType.XLIB)\n" +
    "var desc = vulkease.buffer_desc({ size: 64, usage: 0, debugName: \"buf\" })\n" +
    "ensure(desc.size == 64 && desc.debugName == \"buf\")\n" +
    "var version = vulkease.version()\n" +
    "ensure(version.major == 2)\n" +
    "ensure(len(vulkease.result_string(vulkease.Result.SUCCESS)) > 0)\n" +
    "var surface_ok = vulkease.instance_extension_available(\"VK_KHR_surface\")\n" +
    "ensure(surface_ok == true || surface_ok == false)\n" +
    "var ctx = nil\n" +
    "try {\n" +
    "    ctx = vulkease.create_context(\"mobius-vulkease-package-test\")\n" +
    "} catch e {\n" +
    "    print(\"vulkease context unavailable: \" + str(e))\n" +
    "    exit(0)\n" +
    "}\n" +
    "var devices = ctx:physical_devices()\n" +
    "ensure(typeof(devices) == \"array\")\n" +
    "if (len(devices) > 0) {\n" +
    "    ensure(typeof(devices[0].name) == \"string\")\n" +
    "    ensure(typeof(devices[0].type) == \"string\")\n" +
    "    var dev = ctx:create_device()\n" +
    "    ensure(typeof(dev) == \"userdata\")\n" +
    "    var vk = dev:vulkan_version()\n" +
    "    ensure(vk.major >= 1)\n" +
    "    var mesh = dev:mesh_shader_supported()\n" +
    "    ensure(mesh == true || mesh == false)\n" +
    "    dev:wait_idle()\n" +
    "    ensure(!dev:is_closed())\n" +
    "    dev:close()\n" +
    "    ensure(dev:is_closed())\n" +
    "}\n" +
    "ensure(!ctx:is_closed())\n" +
    "ctx:close()\n" +
    "ensure(ctx:is_closed())\n" +
    "print(\"vulkease package import ok\")\n"))

var pack_rc = os.system(mobius_bin + " " + pack_tool + " " + package_source + " " + archive_path)
assert_test("pack vulkease package", pack_rc == 0)
assert_test("vulkease archive created", os.is_file(archive_path))

var install_rc = os.system(mobius_bin + " " + install_tool + " " + archive_path + " " + modules_root)
assert_test("install vulkease package", install_rc == 0)
assert_test("installed vulkease manifest exists", os.is_file(os.join(modules_root, "vulkease", "module.yaml")))
assert_test("installed vulkease script exists", os.is_file(os.join(modules_root, "vulkease", "vulkease.mob")))
assert_test("installed vulkease native library exists", os.is_file(os.join(modules_root, "vulkease", "native", "linux-x86_64", "vulkease.so")))
assert_test("installed vulkease runtime library exists", os.is_file(os.join(modules_root, "vulkease", "native", "linux-x86_64", "libvulkease.so")))

var old_cwd = os.getcwd()
assert_test("chdir into workspace", os.chdir(workspace))
var import_rc = os.system(mobius_bin + " " + run_script)
assert_test("import installed vulkease package", import_rc == 0)
assert_test("chdir back to repo root", os.chdir(old_cwd))

os.remove(os.join(modules_root, "vulkease", "native", "linux-x86_64", "libvulkease.so"))
os.remove(os.join(modules_root, "vulkease", "native", "linux-x86_64", "vulkease.so"))
os.rmdir(os.join(modules_root, "vulkease", "native", "linux-x86_64"))
os.rmdir(os.join(modules_root, "vulkease", "native"))
os.remove(os.join(modules_root, "vulkease", "vulkease.mob"))
os.remove(os.join(modules_root, "vulkease", "module.yaml"))
os.rmdir(os.join(modules_root, "vulkease"))
os.rmdir(modules_root)
os.remove(archive_path)
os.remove(run_script)
os.rmdir(workspace)

print("")
print("VulkEase Package Tests: " + str(pass_count) + " passed, " + str(fail_count) + " failed")
if (fail_count == 0) {
    print("ALL TESTS PASSED")
} else {
    exit(1)
}
