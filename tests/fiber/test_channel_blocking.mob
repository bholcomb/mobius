// Test blocking ch.send() and ch.recv() across fibers
print("=== Channel Blocking Tests ===")

import "fiber"

// Test 1: ch.recv() blocks until another fiber sends
var ch1 = fiber.channel(1)

func delayed_send(ch, val) {
    fiber.sleep(50)
    ch.send(val)
    return true
}

var f1 = spawn delayed_send(ch1, 42)

var t0 = clock()
var val = ch1.recv()
var elapsed_ns = clock() - t0
var elapsed_ms = elapsed_ns / 1000000

if (val != 42) {
    print("FAIL: blocking recv got", val, "expected 42")
    exit(1)
}
if (elapsed_ms < 30) {
    print("FAIL: recv returned too fast (", elapsed_ms, "ms) — didn't block")
    exit(1)
}
await f1
print("  blocking recv waited ~" + str(elapsed_ms) + "ms for send")

// Test 2: ch.send() blocks when channel is full until another fiber receives
var ch2 = fiber.channel(1)
ch2.send("fill")

func delayed_recv(ch) {
    fiber.sleep(50)
    return ch.recv()
}

var f2 = spawn delayed_recv(ch2)

var t1 = clock()
ch2.send("blocked_value")
var elapsed_ns2 = clock() - t1
var elapsed_ms2 = elapsed_ns2 / 1000000

if (elapsed_ms2 < 30) {
    print("FAIL: send returned too fast (", elapsed_ms2, "ms) — didn't block on full channel")
    exit(1)
}

var received = await f2
if (received != "fill") {
    print("FAIL: delayed recv got", received, "expected 'fill'")
    exit(1)
}

// Drain the remaining item to confirm it arrived
var remaining = ch2.recv()
if (remaining != "blocked_value") {
    print("FAIL: remaining value was", remaining, "expected 'blocked_value'")
    exit(1)
}

print("  blocking send waited ~" + str(elapsed_ms2) + "ms for recv")

// Test 3: Multiple recv calls block in sequence
var ch3 = fiber.channel(1)

func multi_send(ch, count) {
    for (var i = 0; i < count; i += 1) {
        fiber.sleep(10)
        ch.send(i)
    }
    ch.close()
    return count
}

var f3 = spawn multi_send(ch3, 5)

var sum = 0
try {
    while (true) {
        sum += ch3.recv()
    }
} catch e {
    // ChannelClosedError when drained
}

if (sum != 10) {
    print("FAIL: sequential blocking recv sum =", sum, "expected 10 (0+1+2+3+4)")
    exit(1)
}
await f3
print("  sequential blocking recv collected all values")

print("=== All channel blocking tests passed! ===")
