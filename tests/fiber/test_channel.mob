// Test channel operations
print("=== Channel Tests ===")

// Create a channel
var ch = fiber_channel(3)
if (typeof(ch) != "channel") { print("FAIL: channel type, got", typeof(ch)); exit(1) }

// Non-blocking send/recv
var sent = fiber_try_send(ch, 42)
if (!sent) { print("FAIL: try_send should succeed"); exit(1) }

var val = fiber_try_recv(ch)
if (val != 42) { print("FAIL: try_recv, got", val); exit(1) }

// Empty recv returns nil
var empty = fiber_try_recv(ch)
if (empty != nil) { print("FAIL: empty try_recv should be nil, got", empty); exit(1) }

// Multiple sends
fiber_try_send(ch, 10)
fiber_try_send(ch, 20)
fiber_try_send(ch, 30)

// Channel full - should fail
var overflow = fiber_try_send(ch, 40)
if (overflow) { print("FAIL: full channel try_send should return false"); exit(1) }

// Drain
if (fiber_try_recv(ch) != 10) { print("FAIL: drain 1"); exit(1) }
if (fiber_try_recv(ch) != 20) { print("FAIL: drain 2"); exit(1) }
if (fiber_try_recv(ch) != 30) { print("FAIL: drain 3"); exit(1) }

// Close
fiber_close(ch)

print("=== All channel tests passed! ===")
