// Clean Plugin Architecture Test
// Built-in stdlib (always available) vs Math Extension (plugin)

print("=== Mobius Clean Plugin Architecture Test ===");

print("\n🔧 Built-in Standard Library Functions (Always Available):");
print("print() - This function itself");
print("typeof(42) =", typeof(42));
print("str(3.14) =", str(3.14)); 
print("int(2.7) =", int(2.7));
print("float(5) =", float(5));

print("abs(-10) =", abs(-10));
print("min(1, 2, 3) =", min(1, 2, 3));
print("max(1, 2, 3) =", max(1, 2, 3));
print("pow(2, 3) =", pow(2, 3));
print("sqrt(16) =", sqrt(16));

var text = "Hello";
print("len(text) =", len(text));
print("upper(text) =", upper(text));

print("random() =", random());
print("clock() =", clock());

import "math";

print("\n📦 Math Extension Functions (Plugin-only, via namespace):");
print("math.sin(math.pi / 2) =", math.sin(math.pi / 2));
print("math.cos(0) =", math.cos(0));
print("math.tan(math.pi / 4) =", math.tan(math.pi / 4));

print("math.log(math.e) =", math.log(math.e));
print("math.log10(100) =", math.log10(100));
print("math.exp(1) =", math.exp(1));

print("math.factorial(5) =", math.factorial(5));
print("math.gcd(12, 8) =", math.gcd(12, 8));
print("math.lcm(4, 6) =", math.lcm(4, 6));

print("Math constants:");
print("math.pi =", math.pi);
print("math.e =", math.e);

print("\n✅ Architecture Benefits:");
print("1. Built-in functions always work (no plugin needed)");
print("2. Extensions add specialized functionality via namespaces");
print("3. Clean separation of core vs extended features");
print("4. Plugin failure doesn't break basic functionality");
print("5. Namespaces prevent naming conflicts");

print("\n🎯 This is how plugins should work!");
print("   - Core stdlib: Always available, essential functions (no namespace)");
print("   - Extensions: Add specialized domain-specific functions (with namespace)");
