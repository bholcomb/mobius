// Mathematical utility functions

print("Loading math utilities...");

func factorial(n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

func power(base, exponent) {
    var result = 1;
    var i = 0;
    while (i < exponent) {
        result = result * base;
        i = i + 1;
    }
    return result;
}

func fibonacci(n) {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

print("Math utilities loaded!");
